<!DOCTYPE html>
<html>
<head>
    <title>Cart</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>Your Cart 🛒</h1>

<div class="products">
    <% cart.forEach((item, index) => { %>
        <div class="card">
            <img src="<%= item.image %>" />
            <h3><%= item.name %></h3>
            <p>₹ <%= item.price %></p>

            <form action="/remove/<%= index %>" method="POST">
                <button>Remove</button>
            </form>
        </div>
    <% }) %>
</div>

</body>
</html>
<!DOCTYPE html>
<html>
<head>
    <title>Buy Product</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>Purchase Item 🛒</h1>

<div class="product-card">
    <img src="<%= product.image %>" />
    <h2><%= product.name %></h2>
    <h3>₹ <%= product.price %></h3>

    <h3>Enter Address</h3>
    <input type="text" placeholder="Enter Address" />

    <br><br>

    <button onclick="alert('Order Placed Successfully!')">
        Confirm Order
    </button>
</div>

</body>
</html>